# 1. Use the lightweight uv image with Python 3.12 (Alpine based)
FROM ghcr.io/astral-sh/uv:python3.12-alpine

# 2. Install netcat (busybox-extras contains 'nc' in Alpine)
# We need this for the wait-for-db check in entrypoint.sh
RUN apk add --no-cache busybox-extras

# 3. Set the working directory
WORKDIR /app

# 4. Enable bytecode compilation
ENV UV_COMPILE_BYTECODE=1

# 5. Copy dependency files first for layer caching
COPY pyproject.toml uv.lock ./

# 6. Install dependencies
RUN uv sync --frozen --no-install-project --no-dev

# 7. Copy the entire project (including 'app', 'scripts', and 'entrypoint.sh')
COPY . .

# 8. Make the entrypoint script executable
RUN chmod +x entrypoint.sh

# 9. Expose FastAPI port
EXPOSE 8000

# 10. Use the entrypoint script to handle seeding and startup
ENTRYPOINT ["./entrypoint.sh"]